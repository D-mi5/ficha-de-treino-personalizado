{
  "name": "gerador-ficha-treino-feminino",
  "version": "1.0.0",
  "description": "Gerador de ficha de treino feminino com IA",
  "main": "backend/dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:tailwind\"",
    "dev:server": "tsx watch backend/src/server.ts",
    "dev:tailwind": "tailwindcss -i ./frontend/styles/input.css -o ./frontend/styles/output.css --watch",
    "build": "tsc && npm run build:css",
    "build:css": "tailwindcss -i ./frontend/styles/input.css -o ./frontend/styles/output.css --minify",
    "start": "node backend/dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-playwright-e2e.mjs",
    "test:e2e:runner": "playwright test"
  },
  "keywords": [
    "treino",
    "fitness",
    "ia",
    "tailwind",
    "node"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "openai": "^4.63.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.0.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.0"
  }
}
