NODE_ENV=development
PORT=3000

# CORS: informe os domínios permitidos separados por vírgula.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Provider de IA: use openai ou gemini.
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (fallback/opcional)
OPENAI_API_KEY=sua_chave_openai_aqui
OPENAI_MODEL=gpt-4o-mini

# Observabilidade
LOG_LEVEL=info
